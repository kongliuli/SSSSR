<Page x:Class="Shadowsocks.View.Pages.ServersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dd="urn:gong-wpf-dragdrop"
      xmlns:model="clr-namespace:Shadowsocks.Model"
      Title="服务器">
    <Page.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,10,0,3" />
        </Style>
        <Style x:Key="EditBox" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <BooleanToVisibilityConverter x:Key="Bool2Vis" />
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="服务器" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="管理节点、分组与编辑连接参数" Opacity="0.7" Margin="0,6,0,14" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
            <Button Content="添加" MinWidth="72" Margin="0,0,8,0" Command="{Binding AddCommand}" />
            <Button Content="删除" MinWidth="72" Margin="0,0,8,0" Command="{Binding DeleteCommand}" />
            <Button Content="保存" MinWidth="72" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
            <Button Content="从剪贴板导入" MinWidth="72" Margin="0,0,8,0" Command="{Binding ImportFromClipboardCommand}" />
            <Button Content="二维码" MinWidth="72" Margin="0,0,16,0"
                    Command="{Binding ShowQrCodeCommand}"
                    IsEnabled="{Binding IsServerSelected}" />
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Opacity="0.8" />
        </StackPanel>

        <!-- Master / detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: node tree -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="6">
                <TreeView x:Name="ServersTree"
                          BorderThickness="0"
                          Background="Transparent"
                          ItemsSource="{Binding Nodes}"
                          dd:DragDrop.IsDragSource="True"
                          dd:DragDrop.IsDropTarget="True"
                          dd:DragDrop.DropHandler="{Binding}"
                          SelectedItemChanged="ServersTree_OnSelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type model:ServerTreeViewModel}"
                                                  ItemsSource="{Binding Nodes}">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <CheckBox VerticalAlignment="Center" Margin="0,0,6,0"
                                          IsChecked="{Binding Server.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Server">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent" />

            <!-- Right: editor -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsServerSelected, Converter={StaticResource Bool2Vis}}">
                    <StackPanel DataContext="{Binding SelectedServer}">

                        <TextBlock Text="基本" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />

                        <TextBlock Text="备注 (Remarks)" Style="{StaticResource FieldLabel}" />
                        <TextBox Style="{StaticResource EditBox}"
                                 Text="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="地址 (Server)" Style="{StaticResource FieldLabel}" />
                        <TextBox Style="{StaticResource EditBox}"
                                 Text="{Binding server, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="端口 (Port)" Style="{StaticResource FieldLabel}" />
                                <TextBox Style="{StaticResource EditBox}"
                                         Text="{Binding Server_Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="UDP 端口 (Udp Port)" Style="{StaticResource FieldLabel}" />
                                <TextBox Style="{StaticResource EditBox}"
                                         Text="{Binding Server_Udp_Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="密码 (Password)" Style="{StaticResource FieldLabel}" />
                        <TextBox Style="{StaticResource EditBox}"
                                 Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="加密 / 协议 / 混淆" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,4" />

                        <TextBlock Text="加密方式 (Method)" Style="{StaticResource FieldLabel}" />
                        <ComboBox IsEditable="True"
                                  ItemsSource="{Binding DataContext.Methods, RelativeSource={RelativeSource AncestorType=Page}}"
                                  Text="{Binding Method, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="协议 (Protocol)" Style="{StaticResource FieldLabel}" />
                        <ComboBox IsEditable="True"
                                  ItemsSource="{Binding DataContext.Protocols, RelativeSource={RelativeSource AncestorType=Page}}"
                                  Text="{Binding Protocol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="协议参数 (ProtocolParam)" Style="{StaticResource FieldLabel}" />
                        <TextBox Style="{StaticResource EditBox}"
                                 Text="{Binding ProtocolParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="混淆 (Obfs)" Style="{StaticResource FieldLabel}" />
                        <ComboBox IsEditable="True"
                                  ItemsSource="{Binding DataContext.ObfsList, RelativeSource={RelativeSource AncestorType=Page}}"
                                  Text="{Binding obfs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="混淆参数 (ObfsParam)" Style="{StaticResource FieldLabel}" />
                        <TextBox Style="{StaticResource EditBox}"
                                 Text="{Binding ObfsParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="分组与高级" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,4" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="分组 (Group)" Style="{StaticResource FieldLabel}" />
                                <TextBox Style="{StaticResource EditBox}"
                                         Text="{Binding Group, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="子标签 (SubTag)" Style="{StaticResource FieldLabel}" />
                                <TextBox Style="{StaticResource EditBox}"
                                         Text="{Binding SubTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <CheckBox Content="UDP over TCP" Margin="0,14,0,0"
                                  IsChecked="{Binding UdpOverTcp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- TODO: 二维码、ss/ssr 链接显示、剪贴板导入、测延迟等高级动作待迁移 -->
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Empty-state hint when no server is selected -->
            <TextBlock Grid.Column="2"
                       Text="从左侧选择一个节点以编辑，或点击「添加」新建节点。"
                       Opacity="0.6" TextWrapping="Wrap"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsServerSelected}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- QR code overlay (toggled by the toolbar "二维码" button) -->
            <Border Grid.Column="0" Grid.ColumnSpan="3"
                    Background="#99000000"
                    Visibility="{Binding IsQrCodeVisible, Converter={StaticResource Bool2Vis}}">
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Style="{StaticResource Card}" MaxWidth="360">
                    <StackPanel>
                        <TextBlock Text="二维码 (SSR 链接)" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,10" />
                        <Image Source="{Binding QrCodeImage}" Width="300" Height="300"
                               Stretch="Uniform" SnapsToDevicePixels="True" />
                        <Button Content="关闭" MinWidth="72" Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                Command="{Binding CloseQrCodeCommand}" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Page>
