<Page x:Class="Shadowsocks.View.Pages.PortForwardingPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sys="clr-namespace:System;assembly=System.Runtime"
      xmlns:enums="clr-namespace:Shadowsocks.Enums"
      Title="端口转发">
    <Page.Resources>
        <!-- Friendly Chinese labels for the PortMapType enum values shown in the Type column. -->
        <ObjectDataProvider x:Key="TypeValues" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:PortMapType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Page.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="端口转发" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="本地端口映射规则：端口转发、强制代理、按规则代理" Opacity="0.7"
                       Margin="0,6,0,18" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="添加" MinWidth="80" Margin="0,0,8,0"
                    Command="{Binding AddCommand}" />
            <Button Content="删除选中" MinWidth="80" Margin="0,0,8,0"
                    Command="{Binding DeleteCommand}" />
            <Button Content="保存" MinWidth="80" Margin="0,0,8,0"
                    Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding StatusText}" Opacity="0.7"
                       VerticalAlignment="Center" Margin="8,0,0,0" />
        </StackPanel>

        <!-- Rules grid inside a Fluent card frame -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="10" Padding="2">
            <DataGrid ItemsSource="{Binding Rules}"
                      SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Background="Transparent"
                      BorderThickness="0"
                      EnableRowVirtualization="True">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="启用"
                                            Binding="{Binding Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="Auto" MinWidth="48" />

                    <DataGridComboBoxColumn Header="类型"
                                            ItemsSource="{Binding Source={StaticResource TypeValues}}"
                                            SelectedItemBinding="{Binding Type, Mode=TwoWay}"
                                            Width="Auto" MinWidth="110" />

                    <!-- Server / id: friendly picker. Stored value is Server.Id (or the group
                         name, or empty = any). The candidate list comes from the page VM's
                         ServerOptions; a template column is used so the cell ComboBox can reach
                         the page DataContext (DataGridComboBoxColumn cannot, being outside the
                         visual tree). SelectedValue stores the option's Id back into the row. -->
                    <DataGridTemplateColumn Header="服务器/ID" Width="*" MinWidth="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding Id}"
                                                VerticalAlignment="Center" Margin="6,0,0,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.ServerOptions, RelativeSource={RelativeSource AncestorType=Page}}"
                                          DisplayMemberPath="Display"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="本地端口"
                                        Binding="{Binding LocalPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="Auto" MinWidth="90" />

                    <DataGridTextColumn Header="目标地址"
                                        Binding="{Binding ServerAddr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" MinWidth="140" />

                    <DataGridTextColumn Header="目标端口"
                                        Binding="{Binding ServerPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="Auto" MinWidth="90" />

                    <DataGridTextColumn Header="备注"
                                        Binding="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" MinWidth="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Hint -->
        <TextBlock Grid.Row="3" Margin="0,12,0,0" Opacity="0.6" TextWrapping="Wrap"
                   Text="提示：双击单元格可直接编辑。「服务器/ID」可从下拉中选择节点或分组（留空表示任意）。类型为「端口转发」时，目标地址/端口为转发目标；其它类型可留空。本地端口需为有效端口（1-65535）且不能重复，否则保存时会提示具体行号。保存后立即生效。" />
    </Grid>
</Page>
