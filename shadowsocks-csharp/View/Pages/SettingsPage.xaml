<Page x:Class="Shadowsocks.View.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Shadowsocks.View.Controls"
      xmlns:enums="clr-namespace:Shadowsocks.Enums"
      xmlns:valueConverter="clr-namespace:Shadowsocks.View.ValueConverter"
      Title="设置">
    <Page.Resources>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="MaxWidth" Value="760" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.85" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="MinWidth" Value="120" />
        </Style>
        <Style x:Key="FieldRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="SettingCheck" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <valueConverter:ProxyTypeConverter x:Key="EnumEqualsConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="常规、代理与 PAC、DNS、更新" Opacity="0.7" Margin="0,6,0,18" TextWrapping="Wrap" />

            <!-- ① 常规 -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="常规" Style="{StaticResource CardTitle}" />

                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="语言" Style="{StaticResource FieldLabel}" />
                        <ComboBox MinWidth="200"
                                  ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding Config.LangName, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="主题" Style="{StaticResource FieldLabel}" />
                        <ComboBox MinWidth="200"
                                  ItemsSource="{Binding Themes}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                    </StackPanel>

                    <CheckBox Style="{StaticResource SettingCheck}" Content="开机启动"
                              IsChecked="{Binding AutoStartup, Mode=TwoWay}" />
                    <CheckBox Style="{StaticResource SettingCheck}" Content="切换服务器前断开所有连接"
                              IsChecked="{Binding Config.CheckSwitchAutoCloseAll, Mode=TwoWay}" />
                    <CheckBox Style="{StaticResource SettingCheck}" Content="自动禁用出错服务器"
                              IsChecked="{Binding Config.AutoBan, Mode=TwoWay}" />
                    <CheckBox Style="{StaticResource SettingCheck}" Content="负载均衡"
                              IsChecked="{Binding Config.Random, Mode=TwoWay}" />
                    <CheckBox Style="{StaticResource SettingCheck}" Content="负载均衡仅在所选组内切换"
                              IsChecked="{Binding Config.RandomInGroup, Mode=TwoWay}" />
                    <CheckBox Style="{StaticResource SettingCheck}" Content="同一目标优先使用同一服务器"
                              IsChecked="{Binding Config.SameHostForSameTarget, Mode=TwoWay}" />
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="负载均衡策略" Style="{StaticResource FieldLabel}" />
                        <ComboBox MinWidth="220"
                                  ItemsSource="{Binding BalanceTypes}"
                                  SelectedItem="{Binding Config.BalanceType, Mode=TwoWay}" />
                    </StackPanel>
                    <CheckBox Style="{StaticResource SettingCheck}" Content="启用日志"
                              IsChecked="{Binding Config.LogEnable, Mode=TwoWay}" />

                    <StackPanel Style="{StaticResource FieldRow}" Margin="0,4,0,10">
                        <TextBlock Text="重连次数" Style="{StaticResource FieldLabel}" />
                        <controls:NumberUpDown Width="120" Height="24" MinNum="0" MaxNum="20"
                                               Value="{Binding Config.ReconnectTimes, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="连接超时(秒)" Style="{StaticResource FieldLabel}" />
                        <controls:NumberUpDown Width="120" Height="24" MinNum="0" MaxNum="60"
                                               Value="{Binding Config.ConnectTimeout, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="空闲断开(秒)" Style="{StaticResource FieldLabel}" />
                        <controls:NumberUpDown Width="120" Height="24" MinNum="0" MaxNum="600"
                                               Value="{Binding Config.Ttl, Mode=TwoWay}" />
                    </StackPanel>
                    <Button Content="重置连接默认值" HorizontalAlignment="Left"
                            Command="{Binding ResetReconnectCommand}" />
                </StackPanel>
            </Border>

            <!-- ② 代理与 PAC -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="代理与 PAC" Style="{StaticResource CardTitle}" />

                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="本地端口" Style="{StaticResource FieldLabel}" />
                        <controls:NumberUpDown Width="160" Height="24" MinNum="1" MaxNum="65535"
                                               Value="{Binding Config.LocalPort, Mode=TwoWay}" />
                    </StackPanel>

                    <CheckBox Style="{StaticResource SettingCheck}" Content="允许局域网连接"
                              IsChecked="{Binding Config.ShareOverLan, Mode=TwoWay}" />

                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="代理规则模式" Style="{StaticResource FieldLabel}" />
                        <ComboBox MinWidth="220"
                                  ItemsSource="{Binding ProxyRuleModes}"
                                  SelectedItem="{Binding Config.ProxyRuleMode, Mode=TwoWay}" />
                    </StackPanel>

                    <CheckBox Style="{StaticResource SettingCheck}" Content="PAC 直连走二级代理"
                              IsChecked="{Binding Config.PacDirectGoProxy, Mode=TwoWay}" />

                    <TextBlock Text="二级代理" FontWeight="SemiBold" Opacity="0.85" Margin="0,8,0,8" />
                    <CheckBox Style="{StaticResource SettingCheck}" Content="启用二级代理"
                              IsChecked="{Binding Config.ProxyEnable, Mode=TwoWay}" />
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="代理类型" Style="{StaticResource FieldLabel}" />
                        <ComboBox MinWidth="220"
                                  ItemsSource="{Binding ProxyTypes}"
                                  SelectedItem="{Binding Config.ProxyType, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="服务器地址" Style="{StaticResource FieldLabel}" />
                        <TextBox Width="240" Height="24" VerticalContentAlignment="Center"
                                 Text="{Binding Config.ProxyHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="服务器端口" Style="{StaticResource FieldLabel}" />
                        <controls:NumberUpDown Width="160" Height="24" MinNum="1" MaxNum="65535"
                                               Value="{Binding Config.ProxyPort, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="用户名" Style="{StaticResource FieldLabel}" />
                        <TextBox Width="240" Height="24" VerticalContentAlignment="Center"
                                 Text="{Binding Config.ProxyAuthUser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="密码" Style="{StaticResource FieldLabel}" />
                        <controls:BindablePasswordBox Width="240"
                                                      Password="{Binding Config.ProxyAuthPass, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRow}">
                        <TextBlock Text="UserAgent" Style="{StaticResource FieldLabel}" />
                        <TextBox Width="240" Height="24" VerticalContentAlignment="Center"
                                 Text="{Binding Config.ProxyUserAgent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ③ DNS -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="DNS" Style="{StaticResource CardTitle}" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="DNS 客户端" Style="{StaticResource FieldLabel}" />
                        <ComboBox MinWidth="240"
                                  ItemsSource="{Binding DnsClients}"
                                  SelectedItem="{Binding CurrentDnsClient, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DnsServer}" />
                                        <TextBlock Text=":" />
                                        <TextBlock Text="{Binding Port}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="添加" Margin="10,0,0,0" Command="{Binding AddDnsCommand}" />
                        <Button Content="删除" Margin="6,0,0,0" Command="{Binding DeleteDnsCommand}" />
                    </StackPanel>

                    <!-- Editor for the selected DNS client. Content is empty (collapsed) when none selected. -->
                    <ContentControl Content="{Binding CurrentDnsClient}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <CheckBox Content="启用" Margin="0,0,0,8" IsChecked="{Binding Enable, Mode=TwoWay}" />

                                    <WrapPanel Margin="0,0,0,8">
                                        <RadioButton Content="默认" GroupName="DnsType"
                                                     IsChecked="{Binding DnsType, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static enums:DnsType.Default}}" />
                                        <RadioButton Content="DNS over TLS" Margin="12,0,0,0" GroupName="DnsType"
                                                     IsChecked="{Binding DnsType, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static enums:DnsType.DnsOverTls}}" />
                                        <CheckBox Content="IPv6 优先" Margin="16,0,0,0" IsChecked="{Binding Ipv6First, Mode=TwoWay}" />
                                    </WrapPanel>

                                    <WrapPanel Margin="0,0,0,8">
                                        <CheckBox Content="TCP" IsChecked="{Binding IsTcpEnabled, Mode=TwoWay}" />
                                        <CheckBox Content="UDP" Margin="12,0,0,0" IsChecked="{Binding IsUdpEnabled, Mode=TwoWay}" />
                                    </WrapPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="服务器地址" VerticalAlignment="Center" MinWidth="120" Opacity="0.85" Margin="0,0,12,0" />
                                        <TextBox Width="220" Height="24" VerticalContentAlignment="Center"
                                                 Text="{Binding DnsServer, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="端口" VerticalAlignment="Center" MinWidth="120" Opacity="0.85" Margin="0,0,12,0" />
                                        <controls:NumberUpDown Width="160" Height="24" MinNum="1" MaxNum="65535" Value="{Binding Port, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="超时(ms)" VerticalAlignment="Center" MinWidth="120" Opacity="0.85" Margin="0,0,12,0" />
                                        <controls:NumberUpDown Width="160" Height="24" MinNum="1" MaxNum="10000" Value="{Binding Timeout, Mode=TwoWay}" />
                                    </StackPanel>

                                    <TextBlock Text="EDNS / ECS" FontWeight="SemiBold" Opacity="0.85" Margin="0,6,0,8" />
                                    <CheckBox Content="启用 EDNS" Margin="0,0,0,8" IsChecked="{Binding IsEDnsEnabled, Mode=TwoWay}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="ECS IP" VerticalAlignment="Center" MinWidth="120" Opacity="0.85" Margin="0,0,12,0" />
                                        <TextBox Width="220" Height="24" VerticalContentAlignment="Center"
                                                 Text="{Binding EcsIp, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Source Netmask" VerticalAlignment="Center" MinWidth="120" Opacity="0.85" Margin="0,0,12,0" />
                                        <controls:NumberUpDown Width="120" Height="24" MinNum="0" MaxNum="255" Value="{Binding EcsSourceNetmask, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Scope Netmask" VerticalAlignment="Center" MinWidth="120" Opacity="0.85" Margin="0,0,12,0" />
                                        <controls:NumberUpDown Width="120" Height="24" MinNum="0" MaxNum="255" Value="{Binding EcsScopeNetmask, Mode=TwoWay}" />
                                    </StackPanel>

                                    <TextBlock Text="测试查询" FontWeight="SemiBold" Opacity="0.85" Margin="0,10,0,8" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="测试域名" VerticalAlignment="Center" MinWidth="120" Opacity="0.85" Margin="0,0,12,0" />
                                        <TextBox Width="220" Height="24" VerticalContentAlignment="Center"
                                                 Text="{Binding DataContext.DnsTestHost, RelativeSource={RelativeSource AncestorType=Page}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Content="测试" Margin="10,0,0,0"
                                                Command="{Binding DataContext.TestDnsCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                                        <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.85" TextWrapping="Wrap"
                                                   Text="{Binding DataContext.DnsTestResult, RelativeSource={RelativeSource AncestorType=Page}}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </StackPanel>
            </Border>

            <!-- ④ 更新 -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="更新" Style="{StaticResource CardTitle}" />
                    <CheckBox Style="{StaticResource SettingCheck}" Content="自动检查更新"
                              IsChecked="{Binding Config.AutoCheckUpdate, Mode=TwoWay}" />
                    <CheckBox Style="{StaticResource SettingCheck}" Content="允许预发布版本"
                              IsChecked="{Binding Config.IsPreRelease, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- 操作 -->
            <StackPanel Orientation="Horizontal" MaxWidth="760" HorizontalAlignment="Left" Margin="0,4,0,8">
                <Button Content="保存" MinWidth="96" Command="{Binding SaveCommand}" />
                <Button Content="重置" MinWidth="96" Margin="10,0,0,0" Command="{Binding ResetCommand}" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="16,0,0,0" Opacity="0.8" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
