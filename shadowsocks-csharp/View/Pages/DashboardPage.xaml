<Page x:Class="Shadowsocks.View.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="仪表盘">
    <Page.Resources>
        <Style x:Key="DashCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Width" Value="340" />
        </Style>
        <Style x:Key="CardCaption" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="仪表盘" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="连接状态、实时速度与流量总览" Opacity="0.7" Margin="0,6,0,18" />

            <WrapPanel Orientation="Horizontal">

                <!-- 连接状态 + 模式切换 -->
                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="连接状态" Style="{StaticResource CardCaption}" />
                        <TextBlock Text="{Binding StatusText}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,2" />
                        <TextBlock Text="{Binding CurrentNodeName}" Opacity="0.8" Margin="0,0,0,14" TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Content="直连" MinWidth="64" Margin="0,0,8,0"
                                          IsChecked="{Binding IsDirect, Mode=OneWay}"
                                          Command="{Binding SetModeDirectCommand}" />
                            <ToggleButton Content="PAC" MinWidth="64" Margin="0,0,8,0"
                                          IsChecked="{Binding IsPac, Mode=OneWay}"
                                          Command="{Binding SetModePacCommand}" />
                            <ToggleButton Content="全局" MinWidth="64"
                                          IsChecked="{Binding IsGlobal, Mode=OneWay}"
                                          Command="{Binding SetModeGlobalCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 实时速度曲线 -->
                <Border Style="{StaticResource DashCard}" Width="440">
                    <StackPanel>
                        <TextBlock Text="实时速度" Style="{StaticResource CardCaption}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                            <TextBlock Text="↓" FontWeight="SemiBold" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding DownSpeedText}" FontWeight="SemiBold" Margin="0,0,18,0" />
                            <TextBlock Text="↑" FontWeight="SemiBold" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding UpSpeedText}" FontWeight="SemiBold" />
                        </StackPanel>
                        <lvc:CartesianChart Series="{Binding SpeedSeries}" Height="160" />
                    </StackPanel>
                </Border>

                <!-- 流量总览 -->
                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="流量总览（当前节点）" Style="{StaticResource CardCaption}" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="↓ 下载" Opacity="0.8" Width="80" />
                            <TextBlock Text="{Binding TotalDownText}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="↑ 上传" Opacity="0.8" Width="80" />
                            <TextBlock Text="{Binding TotalUpText}" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
